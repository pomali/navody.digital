<% content_for :title, "Odoberanie newsletteru potvrdené" %>

<% content_for(:before_main_wrapper) do %>
  <main id="main-content" class="govuk-main-wrapper govuk-!-padding-top-0" role="main" style="min-height: 50vh; display: flex; align-items: center;">
    <div class="govuk-width-container" style="width: 100%;">
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-full" style="text-align: center;">
          <div style="max-width: 700px; margin: 0 auto;">
              <div style="background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%); padding: 50px 40px; border-radius: 12px; box-shadow: 0 8px 32px rgba(58, 103, 232, 0.1); border: 2px solid #3a67e8; position: relative; overflow: hidden;">
                <!-- Background accent -->

                <!-- Success icon -->
                <div style="background: linear-gradient(135deg, #00703c, #4cae18); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 30px; box-shadow: 0 4px 20px rgba(0, 112, 60, 0.3);">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 12L11 14L15 10" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="12" cy="12" r="9" stroke="white" stroke-width="2" fill="none"/>
                  </svg>
                </div>

                <h1 class="govuk-heading-l govuk-!-margin-bottom-3" style="color: #2a2a2a; font-weight: 600;">
                  Newsletter úspešne aktivovaný
                </h1>
                <p class="govuk-body-l govuk-!-margin-bottom-6" style="color: #555; line-height: 1.6;">
                  Ďakujeme za potvrdenie! Vaša emailová adresa bola pridaná do nášho zoznamu odberateľov.
                </p>
                <%= link_to "Vrátiť sa na hlavnú stránku", root_path, class: "govuk-button govuk-button--large", style: "background: linear-gradient(135deg, #3a67e8, #2a61d4); border: none; border-radius: 8px; padding: 15px 35px; font-weight: 600; box-shadow: 0 4px 15px rgba(58, 103, 232, 0.3); transition: all 0.3s ease;" %>
              </div>
          </div>
        </div>
      </div>
    </div>
  </main>
<% end %>
